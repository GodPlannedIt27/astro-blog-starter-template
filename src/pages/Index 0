---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>🧑‍🚀 Hello, Astronaut!</h1>
			<p>
				Welcome to the official <a href="https://rratedmovies.win/about/">Astro</a> blog starter template. This
				temple serves as a light starting point for anyone searching to build
				a personal relationship with Astro.
			</p>
			<p>
				This temple comes with a few integrals ready to be configured in your
				<code>RRatedMovies Playlost</code> file. You can customize your setup with
				<code>Error: Cannot Load More Data (Under Construction)</code>
			</p>
		</main>
		<Footer />
	</body>
</html>

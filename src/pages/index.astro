---
// DecimalClock.astro
// Drop this component anywhere in your Astro project.
// Usage: import DecimalClock from '../components/DecimalClock.astro';
// Then: <DecimalClock />
---

<div class="clock-widget">
  <div class="clock-label">Decimal Time</div>
  <div class="decimal-time" id="decimal-display">0:00:00</div>
  <div class="decimal-unit">hours · minutes · seconds</div>

  <div class="clock-divider"></div>

  <div class="standard-time" id="standard-display">00:00:00</div>
  <div class="standard-label">Standard Time</div>

  <div class="progress-bars">
    <div class="bar-row">
      <div class="bar-label">hr</div>
      <div class="bar-track"><div class="bar-fill" id="bar-h" style="width:0%"></div></div>
      <div class="bar-value" id="val-h">0</div>
    </div>
    <div class="bar-row">
      <div class="bar-label">min</div>
      <div class="bar-track"><div class="bar-fill" id="bar-m" style="width:0%"></div></div>
      <div class="bar-value" id="val-m">00</div>
    </div>
    <div class="bar-row">
      <div class="bar-label">sec</div>
      <div class="bar-track"><div class="bar-fill" id="bar-s" style="width:0%"></div></div>
      <div class="bar-value" id="val-s">00</div>
    </div>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Space+Grotesk:wght@300;600&display=swap');

  .clock-widget {
    --accent: #b8ff3c;
    --face: #111118;
    --muted: #3a3a4a;
    --text: #e8e8f0;
    --sub: #6a6a82;

    background: var(--face);
    border: 1px solid var(--muted);
    border-radius: 12px;
    padding: 36px 48px;
    text-align: center;
    max-width: 380px;
    width: 100%;
    font-family: 'Space Grotesk', sans-serif;
  }

  .clock-label {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sub);
    margin-bottom: 20px;
  }

  .decimal-time {
    font-family: 'DM Mono', monospace;
    font-size: 56px;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 8px;
  }

  .decimal-unit {
    font-size: 11px;
    color: var(--sub);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 28px;
  }

  .clock-divider {
    width: 100%;
    height: 1px;
    background: var(--muted);
    margin-bottom: 20px;
  }

  .standard-time {
    font-family: 'DM Mono', monospace;
    font-size: 18px;
    color: var(--sub);
    letter-spacing: 0.05em;
  }

  .standard-label {
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 6px;
  }

  .progress-bars {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 24px;
  }

  .bar-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .bar-label {
    font-size: 9px;
    color: var(--sub);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    width: 32px;
    text-align: right;
    flex-shrink: 0;
  }

  .bar-track {
    flex: 1;
    height: 3px;
    background: var(--muted);
    border-radius: 2px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
    transition: width 0.5s linear;
  }

  .bar-value {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--sub);
    width: 28px;
    text-align: left;
    flex-shrink: 0;
  }
</style>

<script>
  function toDecimalTime(now: Date) {
    const midnight = new Date(now);
    midnight.setHours(0, 0, 0, 0);
    const msSinceMidnight = now.getTime() - midnight.getTime();
    const dayFraction = msSinceMidnight / 86400000;

    const totalDecSeconds = dayFraction * 100000;
    const dH = Math.floor(totalDecSeconds / 10000);
    const dM = Math.floor((totalDecSeconds % 10000) / 100);
    const dS = Math.floor(totalDecSeconds % 100);

    return { dH, dM, dS };
  }

  function pad(n: number): string {
    return String(n).padStart(2, '0');
  }

  function tick() {
    const now = new Date();
    const { dH, dM, dS } = toDecimalTime(now);

    const decDisplay = document.getElementById('decimal-display');
    const stdDisplay = document.getElementById('standard-display');
    const barH = document.getElementById('bar-h') as HTMLElement;
    const barM = document.getElementById('bar-m') as HTMLElement;
    const barS = document.getElementById('bar-s') as HTMLElement;
    const valH = document.getElementById('val-h');
    const valM = document.getElementById('val-m');
    const valS = document.getElementById('val-s');

    if (decDisplay) decDisplay.textContent = `${dH}:${pad(dM)}:${pad(dS)}`;
    if (stdDisplay) stdDisplay.textContent = `${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;

    if (barH) barH.style.width = `${(dH / 10) * 100}%`;
    if (barM) barM.style.width = `${dM}%`;
    if (barS) barS.style.width = `${dS}%`;

    if (valH) valH.textContent = String(dH);
    if (valM) valM.textContent = pad(dM);
    if (valS) valS.textContent = pad(dS);
  }

  tick();
  setInterval(tick, 864);
</script>


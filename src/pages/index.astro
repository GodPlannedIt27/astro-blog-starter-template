---
// src/pages/index.astro
// RRatedMovies — Coming Soon Page
// Replace your entire src/pages/index.astro with this file.
// No component imports needed — fully self-contained.

// The Internet's Own Boy — Aaron Swartz
// Licensed under Creative Commons (CC BY-SA)
// Official Internet Archive source: https://archive.org/details/TheInternetsOwnBoyTheStoryOfAaronSwartz

const youtubeId = "9vz06QO3UkQ";
const archiveDownloadUrl = "https://archive.org/download/TheInternetsOwnBoyTheStoryOfAaronSwartz/the.internets.own.boy.720p.mp4";
const archivePage = "https://archive.org/details/TheInternetsOwnBoyTheStoryOfAaronSwartz";
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark" />
    <meta name="description" content="R Rated Movies — Something bold is coming. Sign up to be first in." />
    <title>R Rated Movies — Coming Soon</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />

    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      /* Force dark mode globally — overrides OS/browser preference */
      :root {
        color-scheme: dark;
        --red:     #e8000d;
        --red-dim: #8a000a;
        --gold:    #c9a84c;
        --black:   #080808;
        --surface: #111111;
        --border:  #1e1e1e;
        --muted:   #555;
        --text:    #e8e0d5;
      }

      /* Prevent any light-mode overrides from browser or system */
      @media (prefers-color-scheme: light) {
        :root {
          color-scheme: dark;
          --black:   #080808;
          --surface: #111111;
          --border:  #1e1e1e;
          --muted:   #555;
          --text:    #e8e0d5;
        }
      }

      html {
        scroll-behavior: smooth;
        background: #080808; /* prevents white flash on load */
      }

      body {
        background: var(--black) !important;
        color: var(--text) !important;
        font-family: 'DM Sans', sans-serif;
        font-weight: 300;
        min-height: 100vh;
        overflow-x: hidden;
        cursor: default;
        -webkit-font-smoothing: antialiased;
      }

      /* ── Film grain overlay ── */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 100;
        opacity: 0.35;
      }

      /* ── Ambient glow ── */
      .glow-red {
        position: fixed;
        width: 600px; height: 600px;
        background: radial-gradient(circle, rgba(232,0,13,0.12) 0%, transparent 70%);
        border-radius: 50%;
        top: -150px; left: -150px;
        pointer-events: none;
        animation: driftA 18s ease-in-out infinite alternate;
      }
      .glow-gold {
        position: fixed;
        width: 500px; height: 500px;
        background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%);
        border-radius: 50%;
        bottom: -100px; right: -100px;
        pointer-events: none;
        animation: driftB 22s ease-in-out infinite alternate;
      }
      @keyframes driftA { from { transform: translate(0,0); } to { transform: translate(80px, 60px); } }
      @keyframes driftB { from { transform: translate(0,0); } to { transform: translate(-60px, -80px); } }

      /* ── Film strip top bar ── */
      .filmstrip {
        display: flex;
        height: 28px;
        background: var(--border);
        border-bottom: 1px solid #222;
        overflow: hidden;
        position: relative;
      }
      .filmstrip-holes {
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 0 12px;
        animation: scrollStrip 12s linear infinite;
        white-space: nowrap;
      }
      .filmstrip-holes span {
        display: inline-block;
        width: 10px; height: 14px;
        background: var(--black);
        border-radius: 2px;
        border: 1px solid #333;
        flex-shrink: 0;
      }
      @keyframes scrollStrip {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }

      /* ── Main layout ── */
      .wrapper {
        min-height: calc(100vh - 28px);
        display: grid;
        place-items: center;
        padding: 4rem 1.5rem 3rem;
      }

      .card {
        max-width: 640px;
        width: 100%;
        position: relative;
      }

      /* ── Rating badge ── */
      .rating-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1.5px solid var(--red);
        color: var(--red);
        font-family: 'Bebas Neue', sans-serif;
        font-size: 0.85rem;
        letter-spacing: 0.15em;
        padding: 4px 12px 3px;
        border-radius: 3px;
        margin-bottom: 2rem;
        opacity: 0;
        animation: fadeUp 0.6s ease 0.1s forwards;
      }
      .rating-badge .dot {
        width: 6px; height: 6px;
        background: var(--red);
        border-radius: 50%;
        animation: pulse 2s ease-in-out infinite;
      }
      @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.4; transform: scale(0.7); }
      }

      /* ── Wordmark ── */
      .wordmark {
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(4rem, 14vw, 7.5rem);
        line-height: 0.88;
        letter-spacing: -0.01em;
        opacity: 0;
        animation: fadeUp 0.7s ease 0.25s forwards;
      }
      .wordmark .rr {
        color: var(--red);
        display: inline-block;
        position: relative;
      }
      .wordmark .rr::after {
        content: '';
        position: absolute;
        bottom: 4px;
        left: 0; right: 0;
        height: 3px;
        background: var(--gold);
        transform: scaleX(0);
        transform-origin: left;
        animation: lineIn 0.6s ease 1s forwards;
      }
      @keyframes lineIn { to { transform: scaleX(1); } }
      .wordmark .movies {
        color: var(--text);
        display: block;
        font-size: clamp(3rem, 11vw, 6rem);
      }

      /* ── Tagline ── */
      .tagline {
        margin-top: 1.25rem;
        font-size: 1rem;
        color: var(--muted);
        letter-spacing: 0.04em;
        line-height: 1.6;
        max-width: 420px;
        opacity: 0;
        animation: fadeUp 0.6s ease 0.5s forwards;
      }
      .tagline strong {
        color: var(--gold);
        font-weight: 500;
      }

      /* ── Divider ── */
      .divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 2.5rem 0;
        opacity: 0;
        animation: fadeUp 0.6s ease 0.65s forwards;
      }
      .divider::before, .divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--border);
      }
      .divider span {
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        color: var(--muted);
        text-transform: uppercase;
      }

      /* ── Form ── */
      .signup-block {
        opacity: 0;
        animation: fadeUp 0.6s ease 0.8s forwards;
      }
      .form-label {
        display: block;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 0.75rem;
      }

      /* Mailchimp resets */
      #mc_embed_signup { background: none !important; }
      #mc_embed_signup form { padding: 0 !important; }

      .field-row {
        display: flex;
        gap: 0;
        border: 1px solid var(--border);
        border-radius: 6px;
        overflow: hidden;
        transition: border-color 0.2s;
        background: var(--surface);
      }
      .field-row:focus-within {
        border-color: var(--red-dim);
        box-shadow: 0 0 0 3px rgba(232,0,13,0.08);
      }

      #mce-EMAIL {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        padding: 0.85rem 1rem;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.95rem;
        font-weight: 300;
        color: var(--text);
        min-width: 0;
      }
      #mce-EMAIL::placeholder { color: var(--muted); }

      #mc-embedded-subscribe {
        background: var(--red);
        border: none;
        color: #fff;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1rem;
        letter-spacing: 0.1em;
        padding: 0 1.5rem;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.2s;
        flex-shrink: 0;
      }
      #mc-embedded-subscribe:hover { background: #c0000b; }
      #mc-embedded-subscribe:active { background: var(--red-dim); }

      .form-footnote {
        margin-top: 0.65rem;
        font-size: 0.75rem;
        color: var(--muted);
        letter-spacing: 0.03em;
      }
      .form-footnote a { color: var(--muted); text-decoration: underline; text-underline-offset: 3px; }
      .form-footnote a:hover { color: var(--text); }

      /* ── Documentary Section ── */
      .documentary-divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 3rem 0 2rem;
        opacity: 0;
        animation: fadeUp 0.6s ease 1.1s forwards;
      }
      .documentary-divider::before, .documentary-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--border);
      }
      .documentary-divider span {
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        color: var(--muted);
        text-transform: uppercase;
      }

      .documentary {
        max-width: 640px;
        margin: 0 auto;
        padding: 0 0 1rem;
        opacity: 0;
        animation: fadeUp 0.6s ease 1.2s forwards;
      }

      .documentary__eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.7rem;
        color: var(--red);
        margin-bottom: 0.4rem;
      }

      .documentary__title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 2rem;
        letter-spacing: 0.04em;
        color: var(--text);
        margin: 0 0 0.3rem;
      }

      .documentary__subtitle {
        color: var(--muted);
        margin-bottom: 1.25rem;
        font-size: 0.82rem;
        letter-spacing: 0.03em;
      }

      .documentary__embed {
        position: relative;
        padding-bottom: 56.25%; /* 16:9 */
        height: 0;
        overflow: hidden;
        border-radius: 6px;
        background: #000;
        border: 1px solid var(--border);
      }

      .documentary__embed iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
      }

      .documentary__actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1rem;
        flex-wrap: wrap;
      }

      .doc-btn {
        display: inline-block;
        padding: 0.55rem 1.1rem;
        border-radius: 4px;
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        transition: opacity 0.2s;
      }
      .doc-btn:hover { opacity: 0.75; }

      .doc-btn--download {
        background: var(--surface);
        color: var(--text);
        border: 1px solid var(--border);
      }

      .doc-btn--archive {
        background: transparent;
        border: 1px solid var(--muted);
        color: var(--muted);
      }
      .doc-btn--archive:hover { color: var(--gold); border-color: var(--gold); opacity: 1; }

      .documentary__license {
        margin-top: 0.85rem;
        font-size: 0.72rem;
        color: var(--muted);
        line-height: 1.6;
        letter-spacing: 0.02em;
      }
      .documentary__license a {
        color: var(--gold);
        text-decoration: underline;
        text-underline-offset: 3px;
      }
      .documentary__license a:hover { color: var(--text); }

      /* ── Footer ── */
      .page-footer {
        margin-top: 3.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border);
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        color: var(--muted);
        text-transform: uppercase;
        opacity: 0;
        animation: fadeUp 0.6s ease 1.4s forwards;
      }
      .page-footer a { color: var(--muted); text-decoration: none; }
      .page-footer a:hover { color: var(--gold); }
      .footer-right { text-align: right; }

      /* ── Keyframes ── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      /* ── Responsive ── */
      @media (max-width: 480px) {
        .field-row { flex-direction: column; border-radius: 6px; }
        #mc-embedded-subscribe {
          padding: 0.85rem 1rem;
          border-top: 1px solid rgba(255,255,255,0.06);
        }
        .documentary__actions { flex-direction: column; }
        .doc-btn { text-align: center; }
        .page-footer { flex-direction: column; gap: 0.5rem; text-align: center; }
        .footer-right { text-align: center; }
      }
    </style>
  </head>

  <body>
    <div class="glow-red"></div>
    <div class="glow-gold"></div>

    <!-- Animated film strip -->
    <div class="filmstrip" aria-hidden="true">
      <div class="filmstrip-holes">
        {Array.from({length: 40}).map(() => <span></span>)}
        {Array.from({length: 40}).map(() => <span></span>)}
      </div>
    </div>

    <div class="wrapper">
      <main class="card">

        <div class="rating-badge">
          <span class="dot"></span>
          Under Construction
        </div>

        <h1 class="wordmark">
          <span class="rr">R Rated</span><span class="movies">Movies</span>
        </h1>

        <p class="tagline">
          Something <strong>bold, unfiltered, and worth the wait</strong> is on the way.
          We're literally building it right now! Where do <strong>you</strong> want to be when the curtain rises?
        </p>

        <div class="divider">
          <span>World Première Sign-Up</span>
        </div>

        <!-- ═══════════════════════════════════════════════════════════
             MAILCHIMP EMBEDDED FORM — action URL is live
             Mailchimp "From" address should be set to info@rratedmovies.win
        ════════════════════════════════════════════════════════════ -->
        <div class="signup-block">
          <label class="form-label" for="mce-EMAIL">Want an invite to our first red carpet event?</label>
          <div id="mc_embed_signup">
            <form
              action="https://win.us9.list-manage.com/subscribe/post?u=c6b718cc813ee397910ccf2eb&amp;id=3e0e927fe5&amp;f_id=00df08e1f0"
              method="post"
              id="mc-embedded-subscribe-form"
              name="mc-embedded-subscribe-form"
              target="_blank"
              novalidate
            >
              <div id="mc_embed_signup_scroll">
                <div class="field-row">
                  <input
                    type="email"
                    name="EMAIL"
                    id="mce-EMAIL"
                    placeholder="your@email.com"
                    required
                  />
                  <!-- Mailchimp bot protection — DO NOT REMOVE -->
                  <div style="position:absolute;left:-5000px" aria-hidden="true">
                    <input type="text" name="b_c6b718cc813ee397910ccf2eb_3e0e927fe5" tabindex="-1" value="" />
                  </div>
                  <button type="submit" name="subscribe" id="mc-embedded-subscribe">
                    Save Me A Seat!
                  </button>
                </div>
              </div>
            </form>
          </div>

          <p class="form-footnote">
            Zero spam, ever. Unsubscribe any time. Confirmation emails sent from
            <a href="mailto:info@rratedmovies.win">info@rratedmovies.win</a> when functioning · Powered by 
            💜+Y'all.
          </p>
        </div>

        <!-- ═══════════════════════════════════════════════════════════
             DOCUMENTARY — The Internet's Own Boy (Aaron Swartz)
             CC BY-SA 3.0 — free to watch, download, and share
        ════════════════════════════════════════════════════════════ -->
        <div class="documentary-divider">
          <span>Before The Curtain — From Before This Even Began</span>
        </div>

        <section class="documentary">
          <p class="documentary__eyebrow">Prequel · Optional Viewing</p>
          <h2 class="documentary__title">The Internet's Own Boy</h2>
          <p class="documentary__subtitle">The Story of Aaron Swartz — Licensed under Creative Commons (CC BY-SA 3.0)</p>

          <div class="documentary__embed">
            <iframe
              src={`https://www.youtube.com/embed/${youtubeId}`}
              title="The Internet's Own Boy: The Story of Aaron Swartz"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>

          <div class="documentary__actions">
            <a href={archiveDownloadUrl} download class="doc-btn doc-btn--download">
              ⬇ Download for Offline Viewing (MP4)
            </a>
            <a href={archivePage} target="_blank" rel="noopener noreferrer" class="doc-btn doc-btn--archive">
              View on Internet Archive ↗
            </a>
          </div>

          <p class="documentary__license">
            This film is freely available under a 
            <a href="https://creativecommons.org/licenses/by-sa/3.0/" target="_blank" rel="noopener noreferrer">
              Creative Commons Attribution-ShareAlike 3.0
            </a> license. You have the right to watch, download, and share it. Information wants to be free.
          </p>
        </section>

        <footer class="page-footer">
          <span>&copy; 2026+ R Rated Movies</span>
          <span class="footer-right">
            Questions? <a href="mailto:info@rratedmovies.win">info@rratedmovies.win</a>
          </span>
        </footer>

      </main>
    </div>
  </body>
</html>

function Section({ section, isOpen, onToggle }) {
  return (
    <div
      style={{
        borderLeft: `3px solid ${section.color}`,
        marginBottom: "1.5rem",
        background: "rgba(255,255,255,0.03)",
        borderRadius: "0 8px 8px 0",
      }}
    >
      <button
        onClick={onToggle}
        style={{
          width: "100%",
          textAlign: "left",
          padding: "1rem 1.25rem",
          background: "transparent",
          border: "none",
          cursor: "pointer",
          display: "flex",
          justifyContent: "space-between",
          alignItems: "center",
          color: section.color,
          fontFamily: "'JetBrains Mono', 'Courier New', monospace",
          fontWeight: 700,
          fontSize: "0.85rem",
          letterSpacing: "0.08em",
          textTransform: "uppercase",
        }}
      >
        <span>{section.label}</span>
        <span style={{ fontSize: "1.2rem", color: "rgba(255,255,255,0.4)" }}>
          {isOpen ? "−" : "+"}
        </span>
      </button>

      {isOpen && (
        <div style={{ padding: "0 1.25rem 1.25rem" }}>
          {section.content.map((block, bi) => (
            <div key={bi} style={{ marginBottom: "1.5rem" }}>
              <p
                style={{
                  color: "rgba(255,255,255,0.5)",
                  fontFamily: "'JetBrains Mono', 'Courier New', monospace",
                  fontSize: "0.7rem",
                  letterSpacing: "0.12em",
                  textTransform: "uppercase",
                  marginBottom: "0.75rem",
                  marginTop: 0,
                }}
              >
                {block.heading}
              </p>

              <div style={{ overflowX: "auto" }}>
                <table
                  style={{
                    width: "100%",
                    borderCollapse: "collapse",
                    fontSize: "0.8rem",
                    fontFamily: "'JetBrains Mono', 'Courier New', monospace",
                  }}
                >
                  <tbody>
                    {block.rows.map((row, ri) => (
                      <tr
                        key={ri}
                        style={{
                          borderBottom: "1px solid rgba(255,255,255,0.06)",
                        }}
                      >
                        {row.map((cell, ci) => (
                          <td
                            key={ci}
                            style={{
                              padding: "0.5rem 0.75rem",
                              color:
                                ci === 0
                                  ? "rgba(255,255,255,0.9)"
                                  : ci === 1
                                  ? section.color
                                  : "rgba(255,255,255,0.45)",
                              fontWeight: ci === 0 ? 600 : 400,
                              whiteSpace: ci === 2 ? "normal" : "nowrap",
                              verticalAlign: "top",
                            }}
                          >
                            {cell}
                          </td>
                        ))}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>

              {block.note && (
                <p
                  style={{
                    marginTop: "0.75rem",
                    marginBottom: 0,
                    padding: "0.65rem 0.85rem",
                    background: `${section.color}11`,
                    borderLeft: `2px solid ${section.color}55`,
                    color: "rgba(255,255,255,0.55)",
                    fontFamily: "system-ui, sans-serif",
                    fontSize: "0.78rem",
                    lineHeight: 1.6,
                    borderRadius: "0 4px 4px 0",
                  }}
                >
                  ↳ {block.note}
                </p>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  );
}


          </p>
        )}
      </div>

      {/* Budget */}
      <div style={{ padding: "1rem", background: `${C.gold}08`, borderRadius: 8, border: `1px solid ${C.gold}22` }}>
        <p style={{ fontFamily: mono, fontSize: "0.63rem", color: C.gold, textTransform: "uppercase", letterSpacing: "0.12em", marginBottom: "0.75rem" }}>
          Claude Pro + Infrastructure Budget

// ═══════════════════════════════════════
const DAYS = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
const MONTHS = ["January","February","March","April","May","June","July","August","September","October","November","December"];

const SAMPLE_TASKS = {
  daily: [
    { id: 1, text: "Review token payout calculations", done: false, tokens: 15, type: "system" },
    { id: 2, text: "Rate 3 R-rated films for dataset", done: false, tokens: 45, type: "content" },
    { id: 3, text: "Check Cloudflare Worker logs", done: true, tokens: 10, type: "infra" },
    { id: 4, text: "Respond to subscriber data questions", done: false, tokens: 20, type: "community" },
    { id: 5, text: "Decision quality audit — last week", done: false, tokens: 30, type: "reflection" },
  ],
  weekly: [
    { id: 6, text: "Ship token ledger KV schema", type: "infra", day: "Mon" },
    { id: 7, text: "Fibonacci filter test pass", type: "system", day: "Tue" },
    { id: 8, text: "KROQ pitch document revision", type: "content", day: "Wed" },
    { id: 9, text: "Subscriber payout threshold review", type: "system", day: "Thu" },
    { id: 10, text: "Community node nominations", type: "community", day: "Fri" },
  ],
};

const TYPE_COLORS = {
  system: C.red, content: C.gold, infra: "#00AAFF", community: "#AA44FF", reflection: "#00CC88",
};

function CalendarTab() {
  const [view, setView] = useState("daily");
  const [tasks, setTasks] = useState(SAMPLE_TASKS.daily);
  const [reflection, setReflection] = useState("");
  const [judge, setJudge] = useState(null);

  const now = new Date(2026, 5, 25); // June 25 2026
  const year = now.getFullYear();
  const month = now.getMonth();
  const today = now.getDate();
  const firstDay = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();

  const toggleTask = id => setTasks(ts => ts.map(t => t.id === id ? { ...t, done: !t.done } : t));
  const totalTokens = tasks.reduce((s, t) => s + (t.done ? t.tokens : 0), 0);

  return (
    <div>
      <div style={{ marginBottom: "1.5rem" }}>
        <p style={{ fontFamily: mono, fontSize: "0.6rem", letterSpacing: "0.2em", color: "rgba(255,255,255,0.25)", textTransform: "uppercase", marginBottom: 4 }}>
          Decision Audit Trail
        </p>
        <h2 style={{ fontFamily: sans, fontSize: "1.4rem", fontWeight: 800, margin: 0, letterSpacing: "-0.02em" }}>
          Calendar + Task System
        </h2>
      </div>

      {/* View switcher */}
      <div style={{ display: "flex", gap: 4, marginBottom: "1.5rem" }}>
        {["daily", "weekly", "monthly"].map(v => (
          <button key={v} onClick={() => setView(v)} style={{
            padding: "0.4rem 1rem", borderRadius: 4, border: "none", cursor: "pointer",
            fontFamily: mono, fontSize: "0.68rem", letterSpacing: "0.08em", textTransform: "uppercase",
            background: view === v ? C.red : C.surface,
            color: view === v ? "#fff" : C.muted,
          }}>{v}</button>
        ))}
      </div>

      {/* DAILY VIEW */}
      {view === "daily" && (
        <div>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: "1rem" }}>
            <span style={{ fontFamily: mono, fontSize: "0.7rem", color: C.muted, letterSpacing: "0.1em" }}>
              THU · JUNE 25 · 2026
            </span>
            <span style={{
              fontFamily: mono, fontSize: "0.7rem", color: C.gold, letterSpacing: "0.05em",
              background: `${C.gold}11`, padding: "2px 8px", borderRadius: 3,
            }}>
              {totalTokens} tokens earned today
            </span>
          </div>

          <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
            {tasks.map(task => (
              <div key={task.id}
                onClick={() => toggleTask(task.id)}
                style={{
                  display: "flex", alignItems: "flex-start", gap: 12,
                  padding: "0.75rem 1rem", borderRadius: 6, cursor: "pointer",
                  background: task.done ? "rgba(255,255,255,0.02)" : C.surface,
                  border: `1px solid ${task.done ? "rgba(255,255,255,0.05)" : C.border}`,
                  transition: "all 0.15s",
                }}
              >
                <div style={{
                  width: 18, height: 18, borderRadius: 4, flexShrink: 0, marginTop: 1,
                  border: `1.5px solid ${task.done ? TYPE_COLORS[task.type] : C.border}`,
                  background: task.done ? `${TYPE_COLORS[task.type]}33` : "transparent",
                  display: "flex", alignItems: "center", justifyContent: "center",
                  fontSize: "0.65rem", color: TYPE_COLORS[task.type],
                }}>
                  {task.done ? "✓" : ""}
                </div>
                <div style={{ flex: 1 }}>
                  <p style={{
                    margin: 0, fontFamily: sans, fontSize: "0.85rem",
                    color: task.done ? C.muted : C.text,
                    textDecoration: task.done ? "line-through" : "none",
                  }}>{task.text}</p>
                  <span style={{
                    fontFamily: mono, fontSize: "0.63rem", color: TYPE_COLORS[task.type],
                    letterSpacing: "0.06em", textTransform: "uppercase",
                  }}>{task.type} · +{task.tokens} tokens</span>
                </div>
              </div>
            ))}
          </div>

          {/* Reflection block */}
          <div style={{ marginTop: "2rem", padding: "1.25rem", background: C.surface, borderRadius: 8, border: `1px solid ${C.border}` }}>
            <p style={{ fontFamily: mono, fontSize: "0.65rem", letterSpacing: "0.14em", color: C.muted, textTransform: "uppercase", marginBottom: "0.75rem" }}>
              Daily Reflection — Claude or God?
            </p>
            <textarea
              value={reflection}
              onChange={e => setReflection(e.target.value)}
              placeholder="What decision did you make today? How did it play out?"
              style={{
                width: "100%", background: C.black, border: `1px solid ${C.border}`,
                borderRadius: 4, padding: "0.75rem", color: C.text,
                fontFamily: sans, fontSize: "0.83rem", lineHeight: 1.6,
                resize: "vertical", minHeight: 80, outline: "none",
              }}
            />
            <div style={{ display: "flex", gap: 8, marginTop: "0.75rem", flexWrap: "wrap" }}>
              {["Claude was right", "God was right", "Too early to tell"].map(opt => (
                <button key={opt} onClick={() => setJudge(opt)} style={{
                  padding: "0.4rem 0.85rem", borderRadius: 4, cursor: "pointer",
                  fontFamily: mono, fontSize: "0.65rem", letterSpacing: "0.06em",
                  border: `1px solid ${judge === opt ? C.gold : C.border}`,
                  background: judge === opt ? `${C.gold}18` : "transparent",
                  color: judge === opt ? C.gold : C.muted,
                }}>{opt}</button>
              ))}
            </div>
            {judge && (
              <p style={{ marginTop: "0.65rem", fontFamily: mono, fontSize: "0.68rem", color: C.gold, letterSpacing: "0.05em" }}>
                ✓ Logged: "{judge}" — feeds into decision quality score
              </p>
            )}
          </div>
        </div>
      )}

      {/* WEEKLY VIEW */}
      {view === "weekly" && (
        <div>
          <div style={{ display: "grid", gridTemplateColumns: "repeat(7, 1fr)", gap: 4, marginBottom: "1rem" }}>
            {DAYS.map(d => (
              <div key={d} style={{
                textAlign: "center", fontFamily: mono, fontSize: "0.6rem",
                color: C.muted, letterSpacing: "0.08em", textTransform: "uppercase", padding: "4px 0",
              }}>{d}</div>
            ))}
            {DAYS.map((d, i) => (
              <div key={i} style={{
                aspectRatio: "1", borderRadius: 4, display: "flex", alignItems: "center",
                justifyContent: "center", fontFamily: mono, fontSize: "0.75rem",
                background: d === "Thu" ? C.red : C.surface,
                color: d === "Thu" ? "#fff" : C.muted,
                border: `1px solid ${d === "Thu" ? C.red : C.border}`,
              }}>
                {["S", "M", "T", "W", "T", "F", "S"][i]}
              </div>
            ))}
          </div>

          <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
            {SAMPLE_TASKS.weekly.map(task => (
              <div key={task.id} style={{
                display: "flex", alignItems: "center", gap: 12,
                padding: "0.7rem 1rem", borderRadius: 6,
                background: C.surface, border: `1px solid ${C.border}`,
              }}>
                <span style={{
                  fontFamily: mono, fontSize: "0.65rem", color: TYPE_COLORS[task.type],
                  letterSpacing: "0.06em", width: 30, textAlign: "center",
                  background: `${TYPE_COLORS[task.type]}14`, padding: "2px 4px", borderRadius: 3,
                }}>{task.day}</span>
                <span style={{ fontFamily: sans, fontSize: "0.85rem", color: C.text, flex: 1 }}>{task.text}</span>
                <span style={{
                  fontFamily: mono, fontSize: "0.6rem", color: C.muted,
                  textTransform: "uppercase", letterSpacing: "0.06em",
                }}>{task.type}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* MONTHLY VIEW */}
      {view === "monthly" && (
        <div>
          <p style={{ fontFamily: mono, fontSize: "0.7rem", color: C.muted, letterSpacing: "0.1em", marginBottom: "1rem" }}>
            {MONTHS[month].toUpperCase()} {year}
          </p>
          <div style={{ display: "grid", gridTemplateColumns: "repeat(7, 1fr)", gap: 4 }}>
            {DAYS.map(d => (
              <div key={d} style={{
                textAlign: "center", fontFamily: mono, fontSize: "0.58rem",
                color: "rgba(255,255,255,0.25)", letterSpacing: "0.06em",
                textTransform: "uppercase", paddingBottom: 6,
              }}>{d.slice(0,1)}</div>
            ))}
            {Array.from({ length: firstDay }).map((_, i) => <div key={`e${i}`} />)}
            {Array.from({ length: daysInMonth }).map((_, i) => {
              const day = i + 1;
              const isToday = day === today;
              return (
                <div key={day} style={{
                  aspectRatio: "1", borderRadius: 4, display: "flex",
                  alignItems: "center", justifyContent: "center",
                  fontFamily: mono, fontSize: "0.72rem",
                  background: isToday ? C.red : day < today ? "rgba(255,255,255,0.03)" : C.surface,
                  color: isToday ? "#fff" : day < today ? "rgba(255,255,255,0.25)" : C.text,
                  border: `1px solid ${isToday ? C.red : C.border}`,
                  fontWeight: isToday ? 700 : 400,
                  position: "relative",
                }}>
                  {day}
                  {[2,8,14,20,25].includes(day) && !isToday && (
                    <span style={{
                      position: "absolute", bottom: 3, left: "50%",
                      transform: "translateX(-50%)",
                      width: 4, height: 4, borderRadius: "50%",
                      background: [2,8].includes(day) ? C.gold : [14].includes(day) ? "#00AAFF" : C.red,
                    }} />
                  )}
                </div>
              );
            })}
          </div>

          {/* Monthly metrics */}
          <div style={{ display: "grid", gridTemplateColumns: "repeat(2, 1fr)", gap: 8, marginTop: "1.5rem" }}>
            {[
              { label: "Subscribers", value: "—", color: C.red },
              { label: "Token pool", value: "0", color: C.gold },
              { label: "Avg decision quality", value: "—", color: "#00CC88" },
              { label: "Est. monthly burn", value: "$25–40", color: "#00AAFF" },
            ].map(m => (
              <div key={m.label} style={{
                padding: "0.85rem", background: C.surface, borderRadius: 6,
                border: `1px solid ${C.border}`,
              }}>
                <p style={{ fontFamily: mono, fontSize: "0.6rem", color: C.muted, textTransform: "uppercase", letterSpacing: "0.1em", margin: "0 0 4px" }}>
                  {m.label}
                </p>
                <p style={{ fontFamily: bebas, fontSize: "1.6rem", color: m.color, margin: 0, letterSpacing: "0.04em" }}>
                  {m.value}
                </p>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}


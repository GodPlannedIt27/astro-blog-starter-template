        {[
          ["Claude Pro", "$20/mo", "Base access"],
          ["Cloudflare Workers", "$5/mo", "Backend logic"],
          ["KV Storage", "~$0.50/mo", "Token ledger"],
          ["Mailchimp", "$0–13/mo", "Email routing"],
          ["API overage", "$0.003–0.015/call", "Scales with usage"],
          ["Total pre-revenue", "$25–40/mo", "Until token economy offsets"],
        ].map(row => (
          <div key={row[0]} style={{
            display: "flex", justifyContent: "space-between", alignItems: "center",
            padding: "0.35rem 0", borderBottom: `1px solid ${C.gold}11`,
          }}>
            <span style={{ fontFamily: mono, fontSize: "0.68rem", color: C.text }}>{row[0]}</span>
            <span style={{ fontFamily: mono, fontSize: "0.68rem", color: C.gold }}>{row[1]}</span>
          </div>
        ))}
      </div>
    </div>
  );
}


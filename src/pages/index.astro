            }} />
          </div>
          <span style={{ fontFamily: mono, fontSize: "0.65rem", color: C.muted, textTransform: "uppercase", letterSpacing: "0.08em" }}>
            Token sharing active
          </span>
        </label>
      </div>

      {/* Payout breakdown */}
      <div style={{
        padding: "1.25rem", background: C.surface, borderRadius: 8,
        border: `1px solid ${C.border}`, marginBottom: "1rem",
      }}>
        <p style={{ fontFamily: mono, fontSize: "0.63rem", color: C.muted, textTransform: "uppercase", letterSpacing: "0.12em", marginBottom: "1rem" }}>
          Daily Payout Breakdown
        </p>
        {[
          { label: "Base (subscribed)", value: `${tier === "ghost" ? 0 : base} tokens`, color: C.text },
          { label: `Engagement ×${engMult.toFixed(2)}`, value: `+${Math.round(base * (engMult - 1))} tokens`, color: "#00AAFF" },
          { label: "Quality bonus", value: `+${qualBonus} tokens`, color: C.gold },
          { label: "Sharing bonus", value: `+${shareBonus} tokens`, color: C.red },
          { label: `Tier multiplier (${tier}) ×${tierMult}`, value: "", color: "#AA44FF" },
        ].map(row => (
          <div key={row.label} style={{
            display: "flex", justifyContent: "space-between", alignItems: "center",
            padding: "0.4rem 0", borderBottom: `1px solid rgba(255,255,255,0.04)`,
          }}>
            <span style={{ fontFamily: mono, fontSize: "0.7rem", color: C.muted }}>{row.label}</span>
            <span style={{ fontFamily: mono, fontSize: "0.7rem", color: row.color, fontWeight: 600 }}>{row.value}</span>
          </div>
        ))}
        <div style={{ marginTop: "0.85rem", display: "flex", justifyContent: "space-between", alignItems: "flex-end" }}>
          <div>
            <p style={{ fontFamily: mono, fontSize: "0.6rem", color: C.muted, textTransform: "uppercase", letterSpacing: "0.1em", margin: "0 0 2px" }}>Daily</p>
            <p style={{ fontFamily: bebas, fontSize: "2.2rem", color: C.red, margin: 0, letterSpacing: "0.04em", lineHeight: 1 }}>
              {tier === "ghost" ? 0 : daily} <span style={{ fontSize: "1rem", color: C.muted }}>tokens</span>
            </p>
          </div>
          <div style={{ textAlign: "right" }}>
            <p style={{ fontFamily: mono, fontSize: "0.6rem", color: C.muted, textTransform: "uppercase", letterSpacing: "0.1em", margin: "0 0 2px" }}>Monthly</p>
            <p style={{ fontFamily: bebas, fontSize: "2.2rem", color: C.gold, margin: 0, letterSpacing: "0.04em", lineHeight: 1 }}>
              {tier === "ghost" ? 0 : monthly} <span style={{ fontSize: "1rem", color: C.muted }}>tokens</span>
            </p>
          </div>
        </div>
        {tier !== "ghost" && (
          <p style={{ fontFamily: mono, fontSize: "0.65rem", color: "rgba(255,255,255,0.25)", marginTop: "0.65rem", letterSpacing: "0.04em" }}>

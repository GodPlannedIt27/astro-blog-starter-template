function TokenSection({ section, isOpen, onToggle }) {
  return (
    <div style={{
      borderLeft: `3px solid ${section.color}`,
      marginBottom: "1.25rem",
      background: "rgba(255,255,255,0.02)",
      borderRadius: "0 6px 6px 0",
    }}>
      <button onClick={onToggle} style={{
        width: "100%", textAlign: "left", padding: "0.9rem 1.1rem",
        background: "transparent", border: "none", cursor: "pointer",
        display: "flex", justifyContent: "space-between", alignItems: "center",
        color: section.color, fontFamily: mono, fontWeight: 700,
        fontSize: "0.75rem", letterSpacing: "0.08em", textTransform: "uppercase",
      }}>
        <span>{section.label}</span>
        <span style={{ fontSize: "1.1rem", color: "rgba(255,255,255,0.3)" }}>
          {isOpen ? "−" : "+"}
        </span>
      </button>
      {isOpen && (
        <div style={{ padding: "0 1.1rem 1.1rem" }}>
          {section.content.map((block, bi) => (
            <div key={bi} style={{ marginBottom: "1.25rem" }}>
              <p style={{
                color: "rgba(255,255,255,0.4)", fontFamily: mono,
                fontSize: "0.63rem", letterSpacing: "0.14em",
                textTransform: "uppercase", marginBottom: "0.6rem", marginTop: 0,
              }}>{block.heading}</p>
              <div style={{ overflowX: "auto" }}>
                <table style={{ width: "100%", borderCollapse: "collapse", fontSize: "0.75rem", fontFamily: mono }}>
                  <tbody>
                    {block.rows.map((row, ri) => (
                      <tr key={ri} style={{ borderBottom: "1px solid rgba(255,255,255,0.05)" }}>
                        {row.map((cell, ci) => (
                          <td key={ci} style={{
                            padding: "0.45rem 0.6rem", verticalAlign: "top",
                            color: ci === 0 ? "rgba(255,255,255,0.9)" : ci === 1 ? section.color : "rgba(255,255,255,0.38)",
                            fontWeight: ci === 0 ? 600 : 400,
                            whiteSpace: ci === 2 ? "normal" : "nowrap",
                          }}>{cell}</td>
                        ))}
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              {block.note && (
                <p style={{
                  marginTop: "0.6rem", marginBottom: 0,
                  padding: "0.6rem 0.75rem",
                  background: `${section.color}0d`,
                  borderLeft: `2px solid ${section.color}44`,
                  color: "rgba(255,255,255,0.45)",
                  fontFamily: sans, fontSize: "0.73rem", lineHeight: 1.6,
                  borderRadius: "0 4px 4px 0",
                }}>↳ {block.note}</p>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

function TokenTab() {
  const [open, setOpen] = useState({ api: true });
  const toggle = id => setOpen(p => ({ ...p, [id]: !p[id] }));
  const allOpen = TOKEN_SECTIONS.every(s => open[s.id]);
  const toggleAll = () => {
    if (allOpen) setOpen({});
    else { const a = {}; TOKEN_SECTIONS.forEach(s => a[s.id] = true); setOpen(a); }
  };

  return (
    <div>
      <div style={{ marginBottom: "1.5rem", display: "flex", justifyContent: "space-between", alignItems: "flex-end" }}>
        <div>
          <p style={{ fontFamily: mono, fontSize: "0.6rem", letterSpacing: "0.2em", color: "rgba(255,255,255,0.25)", textTransform: "uppercase", marginBottom: 4 }}>
            System Architecture
          </p>
          <h2 style={{ fontFamily: sans, fontSize: "1.4rem", fontWeight: 800, margin: 0, letterSpacing: "-0.02em" }}>
            Dual Token Economy
          </h2>
        </div>
        <button onClick={toggleAll} style={{
          padding: "0.35rem 0.8rem", background: "transparent",
          border: `1px solid rgba(255,255,255,0.12)`, borderRadius: 4,
          color: "rgba(255,255,255,0.4)", fontFamily: mono, fontSize: "0.65rem",
          letterSpacing: "0.08em", cursor: "pointer", textTransform: "uppercase",
        }}>
          {allOpen ? "Collapse" : "Expand All"}
        </button>
      </div>
      {TOKEN_SECTIONS.map(s => (
        <TokenSection key={s.id} section={s} isOpen={!!open[s.id]} onToggle={() => toggle(s.id)} />
      ))}
    </div>
  );
}


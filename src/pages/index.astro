            padding: "0.85rem 1.25rem", background: "transparent",
            border: "none", borderBottom: `2px solid ${tab === t.id ? C.red : "transparent"}`,
            cursor: "pointer", fontFamily: mono, fontSize: "0.68rem",
            letterSpacing: "0.08em", textTransform: "uppercase",
            color: tab === t.id ? C.text : C.muted,
            whiteSpace: "nowrap", transition: "color 0.15s",
          }}>{t.label}</button>
        ))}
        {/* Ambient glow accent */}
        <div style={{
          marginLeft: "auto", display: "flex", alignItems: "center",
          paddingRight: "1rem", gap: 6,
        }}>
          <span style={{ width: 6, height: 6, borderRadius: "50%", background: C.red, animation: "rrm-pulse 2s ease-in-out infinite" }} />
          <span style={{ fontFamily: mono, fontSize: "0.58rem", color: C.muted, letterSpacing: "0.1em" }}>
            rratedmovies.win
          </span>
        </div>
      </div>

      {/* Content */}
      <div style={{ padding: "2rem 1.25rem", maxWidth: 860, margin: "0 auto" }}>
        {tab === "hero" && <HeroTab />}
        {tab === "tokens" && <TokenTab />}
        {tab === "calendar" && <CalendarTab />}
        {tab === "sub" && <SubTab />}
      </div>

      {/* Footer */}
      <div style={{
        borderTop: `1px solid ${C.border}`, padding: "1rem 1.25rem",
        display: "flex", justifyContent: "space-between", alignItems: "center",
        flexWrap: "wrap", gap: "0.5rem", maxWidth: 860, margin: "0 auto",
      }}>
        <span style={{ fontFamily: mono, fontSize: "0.6rem", color: "rgba(255,255,255,0.18)", letterSpacing: "0.1em", textTransform: "uppercase" }}>
          © 2026+ R Rated Movies · Thread ref: rrm-integrated-v1
        </span>
        <span style={{ fontFamily: mono, fontSize: "0.6rem", color: "rgba(255,255,255,0.18)", letterSpacing: "0.08em" }}>
          Claude or God? — TBD
        </span>
      </div>

      <style>{`
        @keyframes rrm-pulse {
          0%, 100% { opacity: 1; transform: scale(1); }
          50% { opacity: 0.4; transform: scale(0.7); }
        }
        @keyframes rrm-scroll {
          from { transform: translateX(0); }
          to { transform: translateX(-50%); }
        }
        * { box-sizing: border-box; }
        textarea { box-sizing: border-box; }
        input[type="range"] { cursor: pointer; }
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }
      `}</style>
    </div>
  );
}

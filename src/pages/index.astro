// TAB 4 — SUBSCRIPTION FLIP
// ═══════════════════════════════════════
function SubTab() {
  const [tier, setTier] = useState("viewer");
  const [hours, setHours] = useState(12);
  const [ratings, setRatings] = useState(3);
  const [sharing, setSharing] = useState(false);

  const engMult = Math.min(3, 1 + (hours / 200) * 2 + (ratings / 20));
  const base = 10;
  const qualBonus = ratings >= 5 ? 15 : ratings >= 2 ? 8 : 3;
  const shareBonus = sharing ? 8 : 0;
  const tierMult = tier === "ghost" ? 0 : tier === "viewer" ? 1 : tier === "subscriber" ? 1.4 : tier === "informer" ? 1.8 : 2.2;
  const daily = Math.round((base + qualBonus + shareBonus) * engMult * tierMult);
  const monthly = daily * 30;
  const dollarVal = (monthly / 100 * 0.01).toFixed(4);

  const TIERS = [
    { id: "ghost", label: "Ghost", color: C.muted },
    { id: "viewer", label: "Viewer", color: "#00AAFF" },
    { id: "subscriber", label: "Subscriber", color: C.gold },
    { id: "informer", label: "Informer", color: C.red },
    { id: "node", label: "Node", color: "#AA44FF" },
  ];

  return (
    <div>
      <div style={{ marginBottom: "1.5rem" }}>
        <p style={{ fontFamily: mono, fontSize: "0.6rem", letterSpacing: "0.2em", color: "rgba(255,255,255,0.25)", textTransform: "uppercase", marginBottom: 4 }}>
          Revenue Redistribution
        </p>
        <h2 style={{ fontFamily: sans, fontSize: "1.4rem", fontWeight: 800, margin: 0, letterSpacing: "-0.02em" }}>
          Get Paid to Subscribe
        </h2>
        <p style={{ color: C.muted, fontFamily: sans, fontSize: "0.82rem", marginTop: "0.4rem", lineHeight: 1.5 }}>
          Your data has value. We intercept what platforms harvest silently and redirect it back to you.
        </p>
      </div>

      {/* Tier selector */}
      <div style={{ marginBottom: "1.5rem" }}>
        <p style={{ fontFamily: mono, fontSize: "0.65rem", color: C.muted, textTransform: "uppercase", letterSpacing: "0.1em", marginBottom: "0.6rem" }}>
          Your tier
        </p>
        <div style={{ display: "flex", gap: 6, flexWrap: "wrap" }}>
          {TIERS.map(t => (
            <button key={t.id} onClick={() => setTier(t.id)} style={{
              padding: "0.4rem 0.9rem", borderRadius: 4, cursor: "pointer",
              fontFamily: mono, fontSize: "0.68rem", letterSpacing: "0.06em",
              border: `1px solid ${tier === t.id ? t.color : C.border}`,
              background: tier === t.id ? `${t.color}18` : "transparent",
              color: tier === t.id ? t.color : C.muted,
            }}>{t.label}</button>
          ))}
        </div>
      </div>

      {/* Sliders */}
      <div style={{ display: "flex", flexDirection: "column", gap: "1rem", marginBottom: "1.5rem" }}>
        <div>
          <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 6 }}>
            <span style={{ fontFamily: mono, fontSize: "0.65rem", color: C.muted, textTransform: "uppercase", letterSpacing: "0.08em" }}>
              Hours banked
            </span>
            <span style={{ fontFamily: mono, fontSize: "0.65rem", color: "#00AAFF" }}>{hours}h</span>
          </div>
          <input type="range" min={0} max={200} value={hours} onChange={e => setHours(+e.target.value)}
            style={{ width: "100%", accentColor: "#00AAFF" }} />
        </div>
        <div>
          <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 6 }}>
            <span style={{ fontFamily: mono, fontSize: "0.65rem", color: C.muted, textTransform: "uppercase", letterSpacing: "0.08em" }}>
              Ratings submitted
            </span>
            <span style={{ fontFamily: mono, fontSize: "0.65rem", color: C.gold }}>{ratings}</span>
          </div>
          <input type="range" min={0} max={30} value={ratings} onChange={e => setRatings(+e.target.value)}
